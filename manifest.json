{
  "manifest_version": "0.3",
  "name": "wsdot-mcp-server",
  "version": "0.1.5",
  "description": "Query WA highway conditions, ferry schedules, vessel locations, toll rates, border waits, and alerts via MCP. STDIO or Streamable HTTP.",
  "author": { "name": "cyanheads" },
  "repository": {
    "type": "git",
    "url": "https://github.com/cyanheads/wsdot-mcp-server"
  },
  "homepage": "https://github.com/cyanheads/wsdot-mcp-server#readme",
  "license": "Apache-2.0",
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_AUTH_MODE": "none",
        "NODE_ENV": "production",
        "WSDOT_ACCESS_CODE": "${user_config.WSDOT_ACCESS_CODE}"
      }
    }
  },
  "compatibility": {
    "runtimes": { "node": ">=24.0.0" }
  },
  "tools_generated": true,
  "prompts_generated": true,
  "user_config": {
    "WSDOT_ACCESS_CODE": {
      "type": "string",
      "title": "WSDOT Access Code",
      "description": "WSDOT Traveler API access code. Register at wsdot.wa.gov/Traffic/api/.",
      "required": true,
      "sensitive": false
    }
  }
}
